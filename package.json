{
  "name": "paranoia",
  "productName": "PARANOIA",
  "version": "1.0.0",
  "description": "First-person psychological horror game. You are being observed.",
  "author": "vamp9",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "three": "^0.170.0"
  },
  "build": {
    "appId": "com.vamp9.paranoia",
    "productName": "PARANOIA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "lib/**/*",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "PARANOIA-v${version}-win64.exe"
    }
  }
}
