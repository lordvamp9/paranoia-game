; PARANOIA — Godot 4.x project (migration target)
; Generated in Session 1 (architecture). Wired up further in Session 2 (Phase 1 impl).
config_version=5

[application]
config/name="PARANOIA"
config/description="First-person psychological horror. You are being observed."
run/main_scene="res://scenes/Game.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"
boot_splash/show_image=false

[autoload]
; Config + World hold settings/data and must load first. Then the Session-9
; required order: GameState, Director, PostFX, Audio (the AudioSynth GDExtension
; wrapper). Runtime cross-references are all fine regardless; _ready has no
; cross-autoload dependencies.
Config="*res://scripts/config.gd"
World="*res://scripts/world.gd"
GameState="*res://scripts/game_state.gd"
Director="*res://scripts/director.gd"
PostFX="*res://scripts/postfx.gd"
Audio="*res://scripts/audio.gd"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[rendering]
; Low internal world resolution is handled per-SubViewport (see docs §5), not globally.
textures/canvas_textures/default_texture_filter=0 ; Nearest — keep the pixelated world look
anti_aliasing/quality/msaa_3d=0
environment/defaults/default_clear_color=Color(0.004, 0.004, 0.012, 1)

[input]
; Mirrors cpp/src/config.h default bindings. Rebindable at runtime via config.gd.
move_forward={"deadzone":0.5,"events":[{"keycode":87,"type":"key"}]}    ; W
move_back={"deadzone":0.5,"events":[{"keycode":83,"type":"key"}]}        ; S
move_left={"deadzone":0.5,"events":[{"keycode":65,"type":"key"}]}        ; A
move_right={"deadzone":0.5,"events":[{"keycode":68,"type":"key"}]}       ; D
sprint={"deadzone":0.5,"events":[{"keycode":4194325,"type":"key"}]}      ; Left Shift
light={"deadzone":0.5,"events":[{"keycode":70,"type":"key"}]}            ; F
interact={"deadzone":0.5,"events":[{"keycode":69,"type":"key"}]}         ; E
pause={"deadzone":0.5,"events":[{"keycode":4194305,"type":"key"}]}       ; Escape
slot_1={"deadzone":0.5,"events":[{"keycode":49,"type":"key"}]}
slot_2={"deadzone":0.5,"events":[{"keycode":50,"type":"key"}]}
slot_3={"deadzone":0.5,"events":[{"keycode":51,"type":"key"}]}
slot_4={"deadzone":0.5,"events":[{"keycode":52,"type":"key"}]}
slot_5={"deadzone":0.5,"events":[{"keycode":53,"type":"key"}]}
